# Dr. Anum Website - Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (Change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration (Gmail example)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
ADMIN_EMAIL=admin@dranum.com

# Clinic Information
CLINIC_PHONE=(555) 123-4567
CLINIC_EMAIL=info@dranum.com
CLINIC_ADDRESS=123 Medical Plaza, Suite 456, Beverly Hills, CA 90210

# Database
DATABASE_PATH=./.tmp/dranum.db

# Admin Default Credentials (Change after first login!)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme123

# Site Configuration
SITE_URL=http://localhost:3000
SITE_NAME=Dr. Anum - Premium Dermatology